# Application
PORT=3000
# Public base URL used to build image file URLs in API responses
APP_BASE_URL=http://localhost:3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=images
# Auto-create/sync schema on boot. Fine for the task; use migrations in production.
DB_SYNCHRONIZE=true

# Storage (filesystem)
STORAGE_DRIVER=filesystem
STORAGE_DIR=./uploads

# Upload limits
MAX_FILE_SIZE_BYTES=15728640
